# Copy this file to .env and fill in real values. .env is gitignored — never commit it.
# Get these from developer.servicetitan.io under your app + Settings > Integrations > API Application Access.

ST_ENVIRONMENT=production
# production -> auth.servicetitan.io / api.servicetitan.io
# integration -> auth-integration.servicetitan.io / api-integration.servicetitan.io (sandbox, for testing only)

ST_CLIENT_ID=
ST_CLIENT_SECRET=
ST_APP_KEY=
ST_TENANT_ID=

# Google Apps Script Web App URL (already live in index.html — only needed here if
# process_month.py should write flags/output directly to the Sheet)
APPS_SCRIPT_URL=
